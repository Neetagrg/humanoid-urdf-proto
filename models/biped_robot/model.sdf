<?xml version="1.0"?>
<sdf version="1.9">
  <model name="ArduBiped_Proto">
    <pose>0 0 0.5 0 0 0</pose>
    <link name="torso">
      <inertial>
        <mass>2.5</mass>
        <inertia>
          <ixx>0.020</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.020</iyy><iyz>0</iyz><izz>0.010</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry><box><size>0.15 0.10 0.30</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>0.15 0.10 0.30</size></box></geometry>
      </visual>
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>1000</update_rate>
      </sensor>
    </link>
    <link name="l_hip_pitch_link">
      <pose>0 0.080 -0.150 0 0 0</pose>
      <inertial><mass>0.100</mass><inertia><ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.0001</iyy><iyz>0</iyz><izz>0.0001</izz></inertia></inertial>
      <collision name="c"><geometry><sphere><radius>0.03</radius></sphere></geometry></collision>
      <visual name="v"><geometry><sphere><radius>0.03</radius></sphere></geometry></visual>
    </link>
    <link name="l_thigh">
      <pose>0 0.080 -0.350 0 0 0</pose>
      <inertial><mass>0.500</mass><inertia><ixx>0.00375</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.00375</iyy><iyz>0</iyz><izz>0.000156</izz></inertia></inertial>
      <collision name="c"><geometry><cylinder><radius>0.025</radius><length>0.3</length></cylinder></geometry></collision>
      <visual name="v"><geometry><cylinder><radius>0.025</radius><length>0.3</length></cylinder></geometry></visual>
    </link>
    <link name="l_foot">
      <pose>0 0.080 -0.500 0 0 0</pose>
      <inertial><mass>0.100</mass><inertia><ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.0001</iyy><iyz>0</iyz><izz>0.0001</izz></inertia></inertial>
      <collision name="c"><geometry><box><size>0.10 0.08 0.02</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.10 0.08 0.02</size></box></geometry></visual>
    </link>
    <link name="r_hip_pitch_link">
      <pose>0 -0.080 -0.150 0 0 0</pose>
      <inertial><mass>0.100</mass><inertia><ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.0001</iyy><iyz>0</iyz><izz>0.0001</izz></inertia></inertial>
      <collision name="c"><geometry><sphere><radius>0.03</radius></sphere></geometry></collision>
      <visual name="v"><geometry><sphere><radius>0.03</radius></sphere></geometry></visual>
    </link>
    <link name="r_thigh">
      <pose>0 -0.080 -0.350 0 0 0</pose>
      <inertial><mass>0.500</mass><inertia><ixx>0.00375</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.00375</iyy><iyz>0</iyz><izz>0.000156</izz></inertia></inertial>
      <collision name="c"><geometry><cylinder><radius>0.025</radius><length>0.3</length></cylinder></geometry></collision>
      <visual name="v"><geometry><cylinder><radius>0.025</radius><length>0.3</length></cylinder></geometry></visual>
    </link>
    <link name="r_foot">
      <pose>0 -0.080 -0.500 0 0 0</pose>
      <inertial><mass>0.100</mass><inertia><ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.0001</iyy><iyz>0</iyz><izz>0.0001</izz></inertia></inertial>
      <collision name="c"><geometry><box><size>0.10 0.08 0.02</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.10 0.08 0.02</size></box></geometry></visual>
    </link>
    <joint name="l_hip_pitch" type="revolute">
      <parent>torso</parent><child>l_hip_pitch_link</child>
      <axis><xyz>0 1 0</xyz><limit><lower>-1.571</lower><upper>0.523</upper><effort>20</effort><velocity>3</velocity></limit></axis>
    </joint>
    <joint name="l_knee" type="revolute">
      <parent>l_hip_pitch_link</parent><child>l_thigh</child>
      <axis><xyz>0 1 0</xyz><limit><lower>0</lower><upper>2.618</upper><effort>15</effort><velocity>3</velocity></limit></axis>
    </joint>
    <joint name="l_ankle" type="fixed">
      <parent>l_thigh</parent><child>l_foot</child>
    </joint>
    <joint name="r_hip_pitch" type="revolute">
      <parent>torso</parent><child>r_hip_pitch_link</child>
      <axis><xyz>0 1 0</xyz><limit><lower>-1.571</lower><upper>0.523</upper><effort>20</effort><velocity>3</velocity></limit></axis>
    </joint>
    <joint name="r_knee" type="revolute">
      <parent>r_hip_pitch_link</parent><child>r_thigh</child>
      <axis><xyz>0 1 0</xyz><limit><lower>0</lower><upper>2.618</upper><effort>15</effort><velocity>3</velocity></limit></axis>
    </joint>
    <joint name="r_ankle" type="fixed">
      <parent>r_thigh</parent><child>r_foot</child>
    </joint>
  </model>
</sdf>