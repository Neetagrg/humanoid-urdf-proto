          </axis>
        </joint>

        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
          <joint_name>l_hip_roll</joint_name>
          <topic>/l_hip_roll/cmd</topic>
          <initial_position>0.0</initial_position>
          <p_gain>2</p_gain><i_gain>0.01</i_gain><d_gain>0.1</d_gain>
          <cmd_max>30</cmd_max><cmd_min>-30</cmd_min>
        </plugin>
        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
          <joint_name>r_hip_roll</joint_name>
          <topic>/r_hip_roll/cmd</topic>
          <initial_position>0.0</initial_position>
          <p_gain>2</p_gain><i_gain>0.01</i_gain><d_gain>0.1</d_gain>
          <cmd_max>30</cmd_max><cmd_min>-30</cmd_min>
        </plugin>
      </model>
  </world>
</sdf>